# ============================================================
# Project H.O.O.D. Website Admin — environment variables
# Copy this file to `.env` for local dev and fill in real values.
# NEVER commit `.env`. In production, set these in Vercel project settings.
# ============================================================

# ---------- CLIENT (browser-exposed; Vite inlines any VITE_* var) ----------
# Safe to expose — the anon key is protected by Supabase Row-Level Security.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------- SERVER (Vercel serverless functions ONLY — never exposed) ----------
# Do NOT prefix these with VITE_. They must never reach the browser bundle.

# Supabase service-role key bypasses RLS. Server-side only.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# GitHub token used to compare/merge staging into main (publish flow) and to
# read/commit page edits from the AI editor. Needs "repo" scope on the site repo.
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=projecthood-site/projecthood
GITHUB_STAGING_BRANCH=staging
GITHUB_MAIN_BRANCH=main

# Anthropic API — powers the "Edit with Claude" page editor (/api/ai-edit).
# Server-side only; NEVER prefix with VITE_ or expose to the browser.
ANTHROPIC_API_KEY=sk-ant-your-secret-key
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: the AI editor verifies the caller's session with the Supabase anon
# key. It falls back to VITE_SUPABASE_ANON_KEY above if this is unset.
# SUPABASE_ANON_KEY=your-anon-public-key
